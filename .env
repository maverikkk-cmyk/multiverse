############################################
# MultiVerse Bot
# Production Environment Variables
############################################

#############################
# Telegram
#############################

BOT_TOKEN=
BOT_USERNAME=

#############################
# Admin
#############################

# Telegram User ID
ADMIN_ID=

# Multiple admins
# Example:
# ADMIN_IDS=123456789,987654321
ADMIN_IDS=

#############################
# Gemini AI
#############################

GEMINI_API_KEY=

#############################
# NewsAPI
#############################

NEWS_API_KEY=

#############################
# OMDb
#############################

OMDB_API_KEY=

#############################
# OCR.Space
#############################

OCR_SPACE_API_KEY=

#############################
# Optional
#############################

PORT=3000
NODE_ENV=production

#############################
# Bot Settings
#############################

PREFIX=/

#############################
# Database
#############################

DATABASE_PATH=./database/data.json

#############################
# Cache
#############################

CACHE_TTL=600

#############################
# Logger
#############################

LOG_LEVEL=info

#############################
# Downloader
#############################

YT_DLP_PATH=yt-dlp

#############################
# API Timeouts
#############################

REQUEST_TIMEOUT=30000

#############################
# Weather
#############################

WEATHER_PROVIDER=open-meteo

#############################
# Default Language
#############################

DEFAULT_LANGUAGE=hi

#############################
# Default Theme
#############################

DEFAULT_THEME=premium

#############################
# Notifications
#############################

DEFAULT_NOTIFICATION=true
